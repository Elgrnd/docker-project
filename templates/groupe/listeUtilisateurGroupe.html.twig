{% extends "base.html.twig" %}

{% block title %}<title>{{ groupe.nom }}</title>{% endblock %}

{% block page_content %}
    <main class="center">
        <h2>{{ groupe.nom }}</h2>

        <h3>Membres du groupe</h3>
        <ul>
            {% for membre in groupe.utilisateurGroupe %}
                <li>
                    {{ membre.login }}
                    {% if is_granted('GROUPE_EDIT', groupe) and membre != groupe.etreChef %}
                        <form method="post"
                              action="{{ path('supprimer_membre_groupe', {id: groupe.id, login: membre.login}) }}"
                              style="display:inline-block;"
                              onsubmit="return confirm('Supprimer {{ membre.login }} du groupe ?');">
                            <button type="submit" class="btn btn-warning btn-sm">Retirer</button>
                        </form>
                    {% endif %}
                </li>
            {% else %}
                <li>Aucun membre.</li>
            {% endfor %}
        </ul>

        {% if is_granted('GROUPE_EDIT', groupe) %}

            <fieldset>
                <legend>Ajouter un membre</legend>
                {{ form_start(formAjouterMembre) }}
                {{ form_row(formAjouterMembre.utilisateur) }}
                <button type="submit" class="btn">Ajouter</button>
                {{ form_end(formAjouterMembre) }}
            </fieldset>
        {% endif %}
        {% if is_granted('GROUPE_LEAVE', groupe) %}
            <form method="post" action="{{ path('quitter_groupe', {id: groupe.id}) }}" onsubmit="return confirm('Voulez-vous vraiment quitter ce groupe ?')">
                <button type="submit" class="btn btn-warning mt-3">Quitter le groupe</button>
            </form>
        {% endif %}

        <div style="margin-top: 20px;">
            <a href="{{ path('mes_groupes') }}" class="btn btn-secondary">← Retour à mes groupes</a>
        </div>
    </main>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}<title>Mes Répertoires</title>{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-yaml">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-yaml"></div>
    </div>


    <div class="container mt-4">
        <h1>Gestion des répertoires</h1>

        {# Messages flash #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        {# Bouton pour afficher le formulaire #}
        <div class="mb-4">
            <a href="#" id="toggleFormBtn" class="btn btn-success">
                ➕ Créer un nouveau répertoire
            </a>
        </div>

        {# Formulaire de création (masqué par défaut) #}
        <div id="formContainer" style="display: none;" class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Nouveau répertoire</h5>
            </div>
            <div class="card-body">
                {{ form_start(formRepertoire, {'attr': {'class': 'needs-validation'}}) }}
                <div class="mb-3">
                    {{ form_label(formRepertoire.name) }}
                    {{ form_widget(formRepertoire.name) }}
                    {{ form_errors(formRepertoire.name) }}
                </div>

                <div class="mb-3">
                    {{ form_label(formRepertoire.parent) }}
                    {{ form_widget(formRepertoire.parent) }}
                    {{ form_errors(formRepertoire.parent) }}
                    <small class="form-text text-muted">
                        Le répertoire personnel est sélectionné par défaut
                    </small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Créer
                    </button>
                    <button type="button" id="cancelBtn" class="btn btn-secondary">
                        ❌ Annuler
                    </button>
                </div>
                {{ form_end(formRepertoire) }}
            </div>
        </div>

        {# Arborescence des répertoires et fichiers #}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📂 Arborescence</h5>
            </div>
            <div class="card-body tree-container">
                {% if repertoireRacine %}
                    {{ _self.render_tree(repertoireRacine) }}
                {% else %}
                    <p class="text-muted">Aucun répertoire trouvé.</p>
                {% endif %}
            </div>
        </div>
    </div>

    {# Macro récursive pour afficher l'arborescence #}
    {% macro render_tree(repertoire) %}
        <div class="tree-item">
            <div class="tree-folder" data-folder-id="{{ repertoire.id }}">
                <span class="toggle-icon">▼</span>
                <i class="bi bi-folder-fill folder-icon"></i>
                <strong>{{ repertoire.name }}</strong>
                <small class="text-muted">
                    ({{ repertoire.yamlFiles|length }} fichier(s),
                    {{ repertoire.children|length }} sous-répertoire(s))
                </small>
            </div>

            <div class="tree-children" data-children-of="{{ repertoire.id }}">
                {# Afficher les fichiers YAML de ce répertoire #}
                {% if repertoire.yamlFiles|length > 0 %}
                    <div class="file-list">
                        {% for file in repertoire.yamlFiles %}
                            <div class="file-item">
                                <div class="file-info">
                                    <i class="bi bi-file-earmark-text file-icon"></i>
                                    <span class="file-name">{{ file.nameFile }}</span>
                                </div>
                                <div class="file-actions">
                                    <i class="bi bi-eye view-icon" title="Afficher"
                                       onclick="afficherContenuYamlFile('{{ file.bodyFile|escape('js') }}')"></i>
                                    <i class="bi bi-download download-icon" title="Télécharger"></i>
                                    <a href="{{ path('modifierYamlFile', {"id": file.id}) }}">
                                        <i class="bi bi-pencil edit-icon" title="Modifier"></i>
                                    </a>
                                    <button data-fichier-id="{{ file.id }}" class="supprimerFichier"
                                            data-csrf-token="{{ csrf_token('delete' ~ file.id) }}">
                                        <i class="bi bi-trash bin-icon" title="Supprimer"></i>
                                    </button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Afficher récursivement les sous-répertoires #}
                {% for child in repertoire.children %}
                    {{ _self.render_tree(child) }}
                {% endfor %}
            </div>
        </div>
    {% endmacro %}



    <style>
        .tree-container {
            font-family: monospace;
        }

        .tree-item {
            padding: 8px 0;
        }

        .tree-folder {
            cursor: pointer;
            user-select: none;
        }

        .tree-folder:hover {
            background-color: #f8f9fa;
        }

        .tree-children {
            margin-left: 25px;
            border-left: 1px dashed #dee2e6;
            padding-left: 10px;
        }

        .folder-icon {
            color: #ffc107;
            margin-right: 5px;
        }

        .file-icon {
            color: #17a2b8;
            margin-right: 5px;
        }

        .toggle-icon {
            display: inline-block;
            width: 20px;
            transition: transform 0.2s;
        }

        .toggle-icon.collapsed {
            transform: rotate(-90deg);
        }

        .file-actions {
            display: inline-flex;
            gap: 10px;
            margin-left: 10px;
        }

        .file-actions i {
            cursor: pointer;
            transition: color 0.2s;
        }

        .view-icon:hover { color: #007bff; }
        .download-icon:hover { color: #28a745; }
        .edit-icon:hover { color: #ffc107; }
        .bin-icon:hover { color: #dc3545; }

        .file-item {
            padding: 5px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .file-info {
            display: flex;
            align-items: center;
        }

        .supprimerFichier {
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
        }

        /* L’arrière-plan flou */
        .overlay-blur {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(6px);
            z-index: 1000;
        }

        /* La fenêtre modale */
        .modal-yaml {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70%;
            max-height: 80%;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
            z-index: 1001;
            overflow: auto;
        }

        /* En-tête de la modale */
        .modal-header {
            display: flex;
            justify-content: flex-end;
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

        .close-modal {
            cursor: pointer;
            font-size: 24px;
            color: #666;
            transition: color 0.2s;
        }

        .close-modal:hover {
            color: #000;
        }

        /* Corps de la modale */
        .modal-body-yaml {
            padding: 20px;
            font-family: monospace;
            white-space: pre-wrap;
            background: #f9f9f9;
            border-radius: 10px;
        }

    </style>

{% endblock %}
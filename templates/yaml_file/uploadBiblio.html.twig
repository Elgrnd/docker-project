{% extends 'base.html.twig' %}

{% block title %}<title>Upload de fichier YAML</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/yaml_file/upload.css') }}">
{% endblock %}

{% block scriptJs %}
    <script src="{{ asset('js/yaml_file/yaml_file.js') }}"></script>
{% endblock %}

{% block page_content %}
    <div class="container mt-5">
        <div class="upload-container">
            <h1 class="text-center mb-4">📤 Importer un fichier YAML dans la bibliothèque</h1>

            {# Informations supplémentaires #}
            <div class="card mt-4 border-info">
                <div class="card-body">
                    <h6 class="card-title">
                        <i class="bi bi-lightbulb text-warning"></i> Conseils
                    </h6>
                    <ul class="mb-0 small">
                        <li>Assurez-vous que votre fichier YAML est valide avant de l'importer</li>
                        <li>Les fichiers ne doivent pas dépasser 2MB</li>
                        <li>Le nom du fichier doit être unique dans votre compte</li>
                    </ul>
                </div>
            </div>

            {{ include('yaml_file/components/formulaire_upload.html.twig', {
                form: formulaireYaml,
                cancel_path: path('bibliotheque')
            }) }}
        </div>
    </div>
{% endblock %}
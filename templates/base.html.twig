<!DOCTYPE html>
<html lang="fr">
<head>
    {% block title %}{% endblock %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
            crossorigin="anonymous"
    >
    {% block stylesheets %} {% endblock %}
    {% block scriptJs %} {% endblock %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <script defer src="{{ asset('bundles/fosjsrouting/js/router.min.js') }}"></script>
    <script defer src="{{ path('fos_js_routing_js', { callback: 'fos.Router.setData' }) }}"></script>
</head>

<body class="bg-light text-dark d-flex flex-column min-vh-100">

<!-- 🔹 Barre de navigation style Docker -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm py-3">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold text-white d-flex align-items-center" href="{{ path('index') }}">
            {% if is_granted('ROLE_USER') %}
                <i class="bi bi-person-circle me-2 fs-4"></i> {{ app.user.login }} -
                {% for role in app.user.roles %}
                    {% if role != 'ROLE_USER' %}
                        {{ (role|trim('ROLE', 'left'))|trim('_', 'left') }}
                    {% endif %}
                {% endfor %}
            {% else %}
                <i class="bi bi-box-seam me-2 fs-4"></i> SAE A3
            {% endif %}
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-lg-center">
                <li class="nav-item mx-2">
                    <a class="nav-link text-white fw-medium" href="{{ path('index') }}">Accueil</a>
                </li>

                {% if not is_granted('ROLE_USER') %}
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('inscription') }}">Inscription</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('connexion') }}">Connexion</a>
                    </li>
                {% else %}
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('repertoire') }}">Répertoire
                            personnel</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('partager_file') }}">Partager un fichier</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('mes_groupes') }}">Groupes</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('file_upload') }}">Importer un fichier</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('bibliotheque') }}">Bibliothèque de
                            stacks</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('gitlab_fichiers') }}">Gitlab</a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item mx-2">
                            <a class="nav-link text-white fw-medium" href="{{ path('panneauAdmin') }}">Panneau de
                                bord</a>
                        </li>
                    {% endif %}
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('listContainers') }}">Liste des
                            conteneurs</a>
                    </li>
                    <li class="nav-item mx-2">
                        <form method="post" action="{{ path('_logout_main') }}" class="d-inline">
                            <button class="btn btn-light btn-sm fw-semibold rounded-pill px-3 ms-lg-2" type="submit">
                                <i class="bi bi-box-arrow-right me-1"></i> Déconnexion
                            </button>
                        </form>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<!-- 🔹 Flash messages -->
<div class="container mt-4">
    {% for success in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ success }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}

    {% for warning in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ warning }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}

    {% for error in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ error }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
</div>

<!-- 🔹 Contenu principal -->
<main class="container my-5">
    {% block page_content %}{% endblock %}
</main>

<!-- 🔹 Footer -->
<footer class="bg-primary text-white text-center py-3 mt-auto shadow-sm">
    <small>© {{ "now"|date("Y") }} SAE A3
        {% if is_granted('ROLE_ADMIN') %}
            {{ 'administrateur' }}
        {% endif %}
    </small>
</footer>

<script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous">
</script>

</body>
</html>
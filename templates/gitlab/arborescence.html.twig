{% extends 'base.html.twig' %}

{% block title %}<title>Arborescence du Dépôt</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/gitlab/arborescence.css') }}">
{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-file">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-file"></div>
    </div>

    <div class="container mt-4">

        <h1 class="mb-4">Répertoires du dépôt Gitlab "{{ project }}"</h1>

        <!-- 🟦 Boutons d’actions GitLab -->
        <div class="mb-4 d-flex gap-3">
            <a href="{{ path('gitlab_url') }}" class="btn btn-primary">
                <i class="bi bi-pencil-square me-1"></i> Modifier l’URL GitLab
            </a>

            <a href="{{ path('gitlab_supprimer_url') }}"
               class="btn btn-danger"
               onclick="return confirm('Voulez-vous vraiment supprimer votre URL GitLab ?')">
                <i class="bi bi-trash me-1"></i> Supprimer l’URL GitLab
            </a>
            <form method="post" action="{{ path('gitlab_sync') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('gitlab_sync') }}">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-arrow-repeat me-1"></i> Actualiser (cache)
                </button>
            </form>
        </div>


        {# --- BLOC CONSEILS --- #}
        <div class="card mt-3 border-info">
            <div class="card-body">
                <h6 class="card-title">
                    Conseils d’utilisation
                </h6>
                <ul class="mb-0 small">
                    <li>
                        Le cache est mis à jour automatiquement lors de l’enregistrement de l’URL GitLab
                        ou manuellement via <strong>Actualiser (cache)</strong>.
                    </li>
                    <li>
                        Les fichiers trop volumineux ou non autorisés sont ignorés lors de la synchronisation
                        (un message explicatif est affiché).
                    </li>
                    <li>
                        Cliquez sur l’icône <i class="bi bi-eye"></i> pour afficher le contenu d’un fichier texte.
                    </li>
                    <li>
                        L’icône <i class="bi bi-download"></i> permet de télécharger le fichier tel qu’il est stocké.
                    </li>
                    <li>
                        En cliquant sur <i class="bi bi-plus-circle text-success"></i>, vous pouvez
                        <strong>importer un fichier GitLab dans votre espace personnel</strong>.
                    </li>
                    <li>
                        Si un fichier portant le même nom existe déjà dans le répertoire choisi,
                        l’import est bloqué.
                    </li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">📂 Arborescence du dépôt</h5>
            </div>

            <div class="card-body tree-container">
                {% import 'gitlab/macroArborescence.html.twig' as tree %}
                <ul class="tree-root">
                    {{ tree.render_tree(tree) }}
                </ul>
            </div>
        </div>
    </div>
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
<head>
    {% block title %}{% endblock %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
            crossorigin="anonymous"
    >
    {% block stylesheets %} {% endblock %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    <script defer src="{{ asset('bundles/fosjsrouting/js/router.min.js') }}"></script>
    <script defer src="{{ path('fos_js_routing_js', { callback: 'fos.Router.setData' }) }}"></script>
    <script src="{{ asset('js/base.js') }}"></script>

    {% block scriptJs %} {% endblock %}
</head>

<body class="bg-light text-dark d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-light bg-white py-3 border-bottom">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold text-primary d-flex align-items-center" href="{{ path('index') }}">
            {% if is_granted('ROLE_USER') %}
                <i class="bi bi-person-circle me-2 fs-4"></i>
                {{ app.user.roles|map(role => role != 'ROLE_USER' ? (role|trim('ROLE', 'left')|trim('_', 'left')) : '')|join('')|default('Étudiant') }} - {{ app.user.login }}
            {% else %}
                <i class="bi bi-box-seam me-2 fs-4"></i> SAE A3
            {% endif %}
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-lg-center">
                {% if is_granted('ROLE_USER') %}
                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('index') }}">Accueil</a>
                    </li>

                    <!-- Menu déroulant Mes Projets -->
                    <li class="nav-item dropdown mx-2">
                        <a class="nav-link dropdown-toggle fw-medium" href="#" id="mesProjetsDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            Mes Projets
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="mesProjetsDropdown">
                            <li>
                                <a class="dropdown-item" href="{{ path('file_upload') }}">
                                    <i class="bi bi-cloud-upload me-2"></i>Importer un fichier
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ path('partages') }}">
                                    <i class="bi bi-share me-2"></i>Partager un fichier
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ path('repertoire') }}">
                                    <i class="bi bi-folder me-2"></i>Répertoire personnel
                                </a>
                            </li>
                            <li class="nav-item mx-2">
                                <a class="dropdown-item" href="{{ path('bibliotheque') }}">
                                    Bibliothèque de stacks
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('mes_groupes') }}">Groupes</a>
                    </li>

                    {% if is_granted('ROLE_PROFESSEUR') %}
                        <li class="nav-item mx-2">
                            <a class="nav-link fw-medium" href="{{ path('liste_etudiants') }}">Liste des étudiants</a>
                        </li>
                    {% endif %}

                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('services_list') }}">Services</a>
                    </li>


                    {#                    <li class="nav-item mx-2"> #}
                    {#                        <a class="nav-link fw-medium" href="{{ path('listContainers') }}">Monitoring</a> #}
                    {#                    </li> #}


                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item mx-2">
                            <a class="nav-link fw-medium" href="{{ path('panneauAdmin') }}">Panneau de bord</a>
                        </li>
                    {% endif %}
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium"
                           href="{{ path('listContainers', {'id': app.user.vm.id}) }}">Liste des
                            conteneurs</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link text-white fw-medium" href="{{ path('accesSFTP') }}"> Accès SFTP/SSH </a>
                    </li>
                    <li class="nav-item mx-2">
                        <form method="post" action="{{ path('_logout_main') }}" class="d-inline"
                              onsubmit="return confirmLogoutVm()">
                            <button class="btn btn-light btn-sm fw-semibold rounded-pill px-3 ms-lg-2" type="submit">
                                <i class="bi bi-box-arrow-right me-1"></i> Déconnexion
                            </button>
                        </form>
                    </li>
                {% else %}
                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('index') }}">Accueil</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('inscription') }}">Inscription</a>
                    </li>
                    <li class="nav-item mx-2">
                        <a class="nav-link fw-medium" href="{{ path('connexion') }}">Connexion</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% for success in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ success }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
    {% for warning in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>{{ warning }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
    {% for error in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ error }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
</div>

<main class="container my-5">
    {% block page_content %}{% endblock %}

    <!-- POPUP POUR CHOISIR LA CLASSE -->
    {% if app.session.get('show_classe_popup') %}
        <div id="classeModal" class="modal show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Choisissez votre classe</h5>
                        <a href="{{ path('ignorer_classe_popup') }}" class="btn-close" aria-label="Fermer"></a>
                    </div>
                    <div class="modal-body">
                        <form method="POST" action="{{ path('choisir_classe') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('choisir_classe') }}">
                            {% set classes_disponibles = app.session.get('classes_disponibles') %}
                            {% for classe in classes_disponibles %}
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="classe_id"
                                           id="classe_{{ classe.id }}" value="{{ classe.id }}">
                                    <label class="form-check-label" for="classe_{{ classe.id }}">
                                        {{ classe.nom }}
                                    </label>
                                </div>
                            {% endfor %}
                            <button type="submit" class="btn btn-primary mt-3">Confirmer</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-backdrop show"></div>
    {% endif %}

</main>

<footer class="text-center py-3 mt-auto">
    <small>© {{ "now"|date("Y") }} SAE A3
        {% if is_granted('ROLE_ADMIN') %}
            {{ 'administrateur' }}
        {% endif %}
    </small>
</footer>

<script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous">
</script>

</body>
</html>
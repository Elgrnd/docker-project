{% extends 'base.html.twig' %}

{% block title %}
    <title>Fichiers YAML - {{ groupe.nom }}</title>
{% endblock %}

{% block page_content %}
    {% block scriptJs %}
        <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
    {% endblock %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-yaml">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-yaml"></div>
    </div>

    <div class="file-explorer" id="fileExplorer">
        <h2 class="title">📂 Fichiers YAML du groupe {{ groupe.nom }}</h2>

        <div class="file-list">
            {% if fichiersPartages|length > 0 %}
                <ul class="list-group">
                    {% for partage in fichiersPartages %}
                        {% set fichier = partage.yamlFile %}
                        <li class="file-item">
                            <div class="file-info">
                                <i class="bi bi-file-earmark-text file-icon"></i>
                                <span class="file-name">{{ fichier.nameFile }}</span>
                            </div>
                            <div class="file-actions">
                                <i class="bi bi-eye view-icon" title="Afficher"
                                   onclick="afficherContenuYamlFile('{{ fichier.bodyFile|escape('js') }}')"></i>

                                {% if partage.droit == 'edition' or groupe.utilisateurChef == app.user or is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('modifier_yaml_file_groupe', {'id': groupe.id, 'yamlId': fichier.id}) }}">
                                        <i class="bi bi-pencil edit-icon" title="Modifier"></i>
                                    </a>
                                {% endif %}

                                {% if groupe.utilisateurChef == app.user or is_granted('ROLE_ADMIN') %}
                                    <form method="post" action="{{ path('supprimer_yaml_groupe', {'id': groupe.id, 'yamlId': fichier.id}) }}" style="display:inline-block;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ fichier.id) }}">
                                        <button type="submit" class="btn btn-link p-0 m-0 supprimerFichier">
                                            <i class="bi bi-trash bin-icon" title="Supprimer"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="empty-msg">Aucun fichier YAML partagé dans ce groupe.</p>
            {% endif %}
        </div>

        <div class="import-section" style="margin-top: 25px;">
            <fieldset style="margin-bottom: 20px;">
                <legend>📥 Importer un nouveau fichier YAML dans le groupe</legend>
                {{ form_start(formImport) }}
                {{ form_row(formImport.yamlFile) }}
                {{ form_row(formImport.droit) }}
                <button type="submit" class="btn btn-primary">Importer</button>
                {{ form_end(formImport) }}
            </fieldset>

            <fieldset>
                <legend>🔁 Ajouter un fichier déjà existant à ce groupe</legend>
                <form method="post" action="{{ path('ajouter_yaml_existant_groupe', {'id': groupe.id}) }}">
                    <div class="mb-3">
                        <label for="yamlExistant" class="form-label">Sélectionnez un de vos fichiers</label>
                        <select name="yamlId" id="yamlExistant" class="form-select" required>
                            <option value="">-- Choisir un fichier --</option>
                            {% for file in yamlFilesUtilisateur %}
                                <option value="{{ file.id }}">{{ file.nameFile }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="droit" class="form-label">Droit d'accès</label>
                        <select name="droit" id="droit" class="form-select">
                            <option value="lecture">Lecture seule</option>
                            <option value="edition">Éditeur</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-secondary">Partager dans le groupe</button>
                </form>
            </fieldset>
        </div>
    </div>

    <style>
        .overlay-blur {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 999;
        }

        .modal-yaml {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background-color: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            max-width: 80%;
            max-height: 80%;
            overflow-y: auto;
            z-index: 1000;
        }

        .modal-header {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 10px;
        }

        .close-modal {
            font-size: 28px;
            font-weight: bold;
            color: #666;
            cursor: pointer;
            transition: color 0.2s ease;
        }

        .close-modal:hover {
            color: #000;
        }

        .modal-body-yaml {
            font-family: monospace;
            white-space: pre-wrap;
            background-color: #f5f5f5;
            padding: 15px;
            border-radius: 8px;
            color: #333;
        }

        .file-explorer {
            border: 1px solid #ccc;
            border-radius: 10px;
            padding: 16px;
            max-width: 700px;
            background-color: #fafafa;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
            font-family: system-ui, sans-serif;
            margin: 20px auto;
        }

        .file-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 10px;
            margin-bottom: 5px;
            border-radius: 8px;
            background-color: white;
            border: 1px solid #e0e0e0;
            transition: background-color 0.2s ease, transform 0.1s ease;
        }

        .file-item:hover {
            background-color: #f2f2f2;
            transform: scale(1.01);
        }

        .file-actions i {
            cursor: pointer;
            margin-left: 10px;
            color: #666;
            transition: color 0.2s ease;
        }

        .file-actions i:hover {
            color: #007bff;
        }

        fieldset {
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 15px;
        }

        legend {
            font-weight: 600;
        }
    </style>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}<title>Liste des conteneurs</title> {% endblock %}
{% block scriptJs %}<script src="{{ asset('js/searchContainers.js') }}"></script>{% endblock %}

{% block page_content %}
<main>
    <h2 class="mb-4">Conteneurs Docker en cours d’exécution</h2>

    <div class="mb-3">
        <input type="text" id="searchInput" class="form-control" placeholder="Rechercher par nom ou ID...">
    </div>

    <table class="table table-striped" id="containersTable">
        <thead>
        <tr>
            <th>Utilisateur</th>
            <th>Nom</th>
            <th>ID</th>
            <th>Statut</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for c in containers %}
            <tr>
                <td>{{ c.user }}</td>
                <td>{{ c.name }}</td>
                <td>{{ c.id }}</td>
                <td>{{ c.status }}</td>
                <td>
                    <a href="{{ path('container_start', {'vmid': c.vmid, 'id': c.id}) }}" class="btn btn-success btn-sm">Run</a>
                    <a href="{{ path('container_stop', {'vmid': c.vmid, 'id': c.id}) }}" class="btn btn-warning btn-sm">Down</a>
                    {% if 'Exited' in c.status %}
                    <a href="{{ path('container_remove', {'vmid': c.vmid, 'id': c.id}) }}" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce conteneur ?')">Delete</a>
                    {% endif %}
                </td>

            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center">Aucun conteneur trouvé.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</main>
    <hr class="my-5">

    <h2 class="mb-4">Monitoring des machines virtuelles Proxmox</h2>

    {% if vms is empty %}
        <p class="text-center text-muted">Aucune VM détectée.</p>
    {% else %}
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
            <tr>
                <th>VMID</th>
                <th>Nom</th>
                <th>Statut</th>
                <th>CPU (%)</th>
                <th>RAM (Mo)</th>
                <th>Disque (Mo)</th>
                <th>Uptime</th>
                <th>Actions</th>
            </tr>
            </thead>

            <tbody>
            {% for vm in vms %}
                <tr>
                    <td>{{ vm.vmid }}</td>
                    <td>{{ vm.name }}</td>

                    <td>
                        {% if vm.status == 'running' %}
                            <span class="badge bg-success">Running</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ vm.status }}</span>
                        {% endif %}
                    </td>

                    <td>
                        {% if vm.cpu is not null %}
                            {{ (vm.cpu * 100)|number_format(1, '.', '') }} %
                        {% else %}
                            -
                        {% endif %}
                    </td>

                    <td>
                        {% if vm.mem and vm.maxmem %}
                            {{ (vm.mem / 1024 / 1024)|number_format(0) }}
                            /
                            {{ (vm.maxmem / 1024 / 1024)|number_format(0) }}
                        {% else %}
                            -
                        {% endif %}
                    </td>

                    <td>
                        {% if vm.disk and vm.maxdisk %}
                            {{ (vm.disk / 1024 / 1024)|number_format(0) }}
                            /
                            {{ (vm.maxdisk / 1024 / 1024)|number_format(0) }}
                        {% else %}
                            -
                        {% endif %}
                    </td>

                    <td>
                        {% if vm.uptime %}
                            {{ (vm.uptime / 3600)|number_format(1) }} h
                        {% else %}
                            -
                        {% endif %}
                    </td>

                    <td>
                        <a href="{{ path('admin_vm_start', {'vmid': vm.vmid}) }}" class="btn btn-success btn-sm">Start</a>
                        <a href="{{ path('admin_vm_stop', {'vmid': vm.vmid}) }}" class="btn btn-warning btn-sm">Stop</a>
                        <a href="{{ path('admin_vm_delete', {'vmid': vm.vmid}) }}" class="btn btn-danger btn-sm"
                           onclick="return confirm('Supprimer cette VM ?')">Delete</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}

{% endblock %}

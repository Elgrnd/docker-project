{% extends "base.html.twig" %}

{% block title %}<title>{{ groupe.nom }}</title>{% endblock %}

{% block scriptJs %}
    <script defer src="{{ asset('js/changeRoleGroupe.js') }}"></script>
{% endblock %}

{% block page_content %}
    <main class="center">
        <h2>{{ groupe.nom }}</h2>

        <h3 class="mt-4">Membres du groupe</h3>

        <table class="table table-striped mt-3">
            <thead>
            <tr>
                <th>Login</th>
                <th>Rôle dans le groupe</th>
                {% if is_granted('GROUPE_MODERATE', groupe) %}
                    <th>Action</th>
                {% endif %}
            </tr>
            </thead>

            <tbody>
            {% for membre in groupe.getMembres() %}
                <tr>
                    <td>{{ membre.login }}</td>

                    {# ====== SELECT ROLE ====== #}
                    <td>
                        {% set pivot = membre.getUtilisateurGroupeRelation(groupe) %}
                        {# pivot.role contient GROUPE_UTILISATEUR / GROUPE_MODERATEUR / GROUPE_CHEF #}

                        {% if is_granted('GROUPE_EDIT', groupe) and membre != groupe.etreChef and membre != app.user %}
                            <select
                                    class="form-select"
                                    data-utilisateur-login="{{ membre.login }}"
                                    data-groupe-id="{{ groupe.id }}"
                            >
                                <option value="GROUPE_UTILISATEUR" {{ pivot.role == 'GROUPE_UTILISATEUR' ? 'selected' }}>Utilisateur</option>
                                <option value="GROUPE_MODERATEUR" {{ pivot.role == 'GROUPE_MODERATEUR' ? 'selected' }}>Modérateur</option>
                                <option value="GROUPE_ADMINISTRATEUR" {{ pivot.role == 'GROUPE_ADMINISTRATEUR' ? 'selected' }}>Administrateur</option>
                            </select>
                        {% else %}
                            {{ (pivot.role|replace({'GROUPE_': ''})|lower)|capitalize }}
                        {% endif %}
                    </td>

                    {# ====== BOUTON RETIRER ====== #}
                    {% if is_granted('GROUPE_MODERATE', groupe) %}
                        <td>
                            {% if membre != groupe.etreChef %}
                                <form method="post"
                                      action="{{ path('supprimer_membre_groupe', {id: groupe.id, login: membre.login}) }}"
                                      onsubmit="return confirm('Supprimer {{ membre.login }} du groupe ?');">
                                    <button type="submit" class="btn btn-warning btn-sm">Retirer</button>
                                </form>
                            {% endif %}
                        </td>
                    {% endif %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center">Aucun membre.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        {% if is_granted('GROUPE_MODERATE', groupe) %}
            <fieldset class="mt-4">
                <legend>Ajouter un membre</legend>
                {{ form_start(formAjouterMembre) }}
                {{ form_row(formAjouterMembre.utilisateur) }}
                <button type="submit" class="btn">Ajouter</button>
                {{ form_end(formAjouterMembre) }}
            </fieldset>
        {% endif %}

        {% if is_granted('GROUPE_LEAVE', groupe) %}
            <form method="post" action="{{ path('quitter_groupe', {id: groupe.id}) }}" class="mt-3"
                  onsubmit="return confirm('Voulez-vous vraiment quitter ce groupe ?')">
                <button type="submit" class="btn btn-warning">Quitter le groupe</button>
            </form>
        {% endif %}

        <div class="mt-4">
            <a href="{{ path('mes_groupes') }}" class="btn btn-secondary">← Retour à mes groupes</a>
        </div>
    </main>
{% endblock %}

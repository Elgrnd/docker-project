<div class="file-item">
    <div class="file-info">
        <i class="bi bi-file-earmark-text file-icon"></i>
        <span class="file-name">{{ name }}</span>
    </div>

    <div class="file-actions">
        {% if item.isText %}
            <i class="bi bi-eye view-icon" title="Afficher"
               onclick="afficherContenuTextFile('{{ (item.body ?? '')|escape('js') }}')"></i>
        {% endif %}

        <i class="bi bi-download download-icon" title="Télécharger"
           onclick="downloadFileById('{{ item.id }}')"></i>

        <a href="{{ path('ajouterAuRepertoireGitlab', { id: item.id }) }}">
            <i class="bi bi-plus-circle" title="Ajouter au répertoire"></i>
        </a>
        {% if app.user.vmStatus == 'ready' and (item.isYaml) %}
            <a href="{{ path('deploy_yaml_file', {id: item.id}) }}"
               onclick="return confirm('Déployer ce fichier sur votre VM ?');">
                <i class="bi bi-rocket-takeoff deploy-icon" title="Déployer"></i>
            </a>
        {% endif %}
    </div>
</div>

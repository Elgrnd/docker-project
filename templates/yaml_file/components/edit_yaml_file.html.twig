<form method="post" id="yaml-form" class="bg-light p-4 rounded shadow-sm">

    {% if show_description %}
        <div class="mb-4">
            <label for="desc" class="form-label fw-semibold">Description</label>
            <textarea id="desc"
                      name="description"
                      class="form-control"
                      rows="3">{{ yamlfile.description }}</textarea>
        </div>
    {% endif %}

    <div class="mb-4" style="height: 70vh;">
        <label for="editor" class="form-label fw-semibold">
            {% if show_description %}Contenu YAML{% endif %}
        </label>
        <textarea id="editor"
                  name="yaml_content"
                  class="form-control h-100">{{ yamlfile.bodyFile }}</textarea>
    </div>

    <input type="hidden" name="_token" value="{{ csrf_token('edit-yaml') }}">

    <div class="d-flex gap-2 justify-content-center mt-4">
        <button type="submit" class="btn btn-primary px-4">
            💾 Enregistrer
        </button>
        <a href="{{ cancel_path }}" class="btn btn-outline-secondary px-4">
            Annuler
        </a>
    </div>

</form>

<article class="groupe-item">
    <h3 class="groupe-name">
        {{ groupe.nom }}
        {% if isAdmin and groupe.etreChef %}
            <span class="groupe-chef">({{ groupe.etreChef.login }})</span>
        {% endif %}
    </h3>

    <div class="groupe-actions">
        <a href="{{ path('voir_groupe', {id: groupe.id}) }}" class="btn btn-secondary">
            Membres
        </a>
        <a href="{{ path('fichiers_groupe', {id: groupe.id}) }}" class="btn btn-primary">
            Fichiers
        </a>
        <a href="{{ path('upload_file_groupe', {id: groupe.id}) }}" class="btn btn-import">
            Importer un fichier
        </a>
        <a href="{{ path('partager_file_groupe', {id: groupe.id}) }}" class="btn btn-shared">
            Partager un fichier
        </a>

        {% if canEdit %}
            <form method="post"
                  action="{{ path('supprimer_groupe', {id: groupe.id}) }}"
                  class="delete-groupe-form"
                  data-confirm-message="Supprimer ce groupe ?">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-groupe-' ~ groupe.id) }}">
                <button type="submit" class="btn btn-danger">Supprimer</button>
            </form>
        {% endif %}


        {% if is_granted('ROLE_PROFESSEUR') %}
            {% if not groupe.vm.vmStatus or groupe.vm.vmStatus == 'none' %}
                <form method="post"
                      action="{{ path('create_vm_groupe', {id: groupe.id}) }}"
                      class="create-groupe-form">
                    <button type="submit" class="btn btn-shared">Créer une VM</button>
                </form>
            {% else %}
                <form method="post"
                      action="{{ path('delete_vm_groupe', {id: groupe.id}) }}"
                      class="delete-groupe-form"
                      data-confirm-message="Supprimer la VM de ce groupe ?">
                    <button type="submit" class="btn btn-danger">Supprimer la VM</button>
                </form>
            {% endif %}
        {% endif %}
    </div>
</article>
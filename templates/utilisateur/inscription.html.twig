{% extends "base.html.twig" %}
{% block title %}<title>Inscription</title>{% endblock %}
{% block page_content %}
<main>
    {{ form_start(formulaireUtilisateur) }}

    <div class="mb-3">
        {{ form_label(formulaireUtilisateur.login, "Login", {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        <p class="text-muted small mb-1">Entre 4 et 20 caractères</p>
        {{ form_widget(formulaireUtilisateur.login, {'attr': {'class': 'form-control rounded-pill'}}) }}
    </div>

    <div class="mb-3">
        {{ form_label(formulaireUtilisateur.plainPassword, "Mot de passe", {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        <p class="text-muted small mb-1">
            Entre 8 et 30 caractères, au moins une minuscule, une majuscule et un nombre
        </p>
        {{ form_widget(formulaireUtilisateur.plainPassword, {'attr': {'class': 'form-control rounded-pill'}}) }}
    </div>

    <div class="mb-4">
        {{ form_label(formulaireUtilisateur.adresseMail, "Adresse mail", {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(formulaireUtilisateur.adresseMail, {'attr': {'class': 'form-control rounded-pill'}}) }}
    </div>

    <div class="d-grid mb-3">
        {{ form_widget(formulaireUtilisateur.inscription, {'attr': {'class': 'btn btn-primary rounded-pill fw-semibold'}}) }}
    </div>

    <div class="text-center">
        <small class="text-muted">
            Déjà un compte ? <a href="{{ path('connexion') }}" class="text-primary fw-medium">Se connecter</a>
        </small>
    </div>
    {{ form_rest(formulaireUtilisateur) }}
    {{ form_end(formulaireUtilisateur) }}
</main>
{% endblock %}
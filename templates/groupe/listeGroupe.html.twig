{% extends "base.html.twig" %}

{% block title %}<title>Mes Groupes</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/groupe/listeGroupe.css') }}">
{% endblock %}

{% block scriptJs %}
    <script src="{{ asset('js/groupes.js') }}"></script>
{% endblock %}

{% block page_content %}
    <h2>
        {% if not is_granted('ROLE_ADMIN') %}Mes {% endif %}Groupes
    </h2>

    {% if groupesMembre is empty %}
        <p class="no-groups">Aucun groupe rejoint.</p>
    {% else %}
        <div class="groupes-list">
            {% for groupe in groupesMembre %}
                {% include 'groupe/groupe.html.twig' with {
                    'groupe': groupe,
                    'isAdmin': is_granted('ROLE_ADMIN'),
                    'canEdit': is_granted('GROUPE_EDIT', groupe)
                } %}
            {% endfor %}
        </div>
    {% endif %}

    <section class="create-groupe-section">
        <h3>Créer un groupe</h3>
        {{ form_start(formGroupe, {'attr': {'class': 'form-groupe'}}) }}
        {{ form_row(formGroupe.nom) }}
        <button type="submit" class="btn btn-primary">Créer</button>
        {{ form_end(formGroupe) }}
    </section>
{% endblock %}
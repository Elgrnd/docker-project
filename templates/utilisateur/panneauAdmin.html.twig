{% extends "base.html.twig" %}
{% block title %}<title>Panneau de bord</title>{% endblock %}
{% block scriptJs %}<script src="{{ asset('js/searchUsers.js') }}"></script>{% endblock %}
{% block page_content %}
    <main>
        <h2 class="mb-4">Conteneurs Docker en cours d’exécution</h2>

        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control" placeholder="Rechercher par login ou par ID...">
        </div>

        <table class="table table-striped" id="usersTable">
            <thead>
            <tr>
                <th>Login</th>
                <th>ID</th>
                <th>Rôles</th>
            </tr>
            </thead>
            <tbody>
            {% for u in utilisateurs %}
                <tr>
                    <td>{{ u.login }}</td>
                    <td>{{ u.id }}</td>
                    <td>{{ u.roles }}</td>
                    <td>

                    </td>

                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center">Aucun conteneur trouvé.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </main>
{% endblock %}
{% extends "base.html.twig" %}

{% block title %}<title>Inscription</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/utilisateur/inscription.css') }}">
{% endblock %}

{% block page_content %}
    <div class="auth-wrapper">
        <div class="auth-card">

            <div class="auth-header">
                <h1>Inscription</h1>
                <p class="auth-subtitle">Créez votre compte</p>
            </div>

            {{ form_start(formulaireUtilisateur, {
                'attr': {'class': 'auth-form needs-validation'}
            }) }}

            <div class="mb-3">
                {{ form_label(formulaireUtilisateur.login, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                <p class="form-hint">Entre 4 et 20 caractères</p>
                {{ form_widget(formulaireUtilisateur.login) }}
                {{ form_errors(formulaireUtilisateur.login) }}
            </div>

            <div class="mb-3">
                {{ form_label(formulaireUtilisateur.plainPassword, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                <p class="form-hint">
                    8 à 30 caractères, avec une minuscule, une majuscule et un chiffre
                </p>
                {{ form_widget(formulaireUtilisateur.plainPassword) }}
                {{ form_errors(formulaireUtilisateur.plainPassword) }}
            </div>

            <div class="mb-4">
                {{ form_label(formulaireUtilisateur.adresseMail, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                {{ form_widget(formulaireUtilisateur.adresseMail) }}
                {{ form_errors(formulaireUtilisateur.adresseMail) }}
            </div>

            {{ form_widget(formulaireUtilisateur.inscription) }}

            <div class="auth-footer text-center">
                <small class="text-muted">
                    Déjà un compte ?
                    <a href="{{ path('connexion') }}" class="text-primary fw-medium">
                        Se connecter
                    </a>
                </small>
            </div>

            {{ form_end(formulaireUtilisateur) }}

        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}<title>Arborescence du Dépôt</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/gitlab/arborescence.css') }}">
{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-yaml">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-yaml"></div>
    </div>

    <div class="container mt-4">

        <h1 class="mb-4">Répertoires du dépôt Gitlab "{{ project }}"</h1>

        <!-- 🟦 Boutons d’actions GitLab -->
        <div class="mb-4 d-flex gap-3">
            <a href="{{ path('gitlab_url') }}" class="btn btn-primary">
                <i class="bi bi-pencil-square me-1"></i> Modifier l’URL GitLab
            </a>

            <a href="{{ path('gitlab_supprimer_url') }}"
               class="btn btn-danger"
               onclick="return confirm('Voulez-vous vraiment supprimer votre URL GitLab ?')">
                <i class="bi bi-trash me-1"></i> Supprimer l’URL GitLab
            </a>
        </div>


        {# --- BLOC CONSEILS --- #}
        <div class="card mt-3 border-info">
            <div class="card-body">
                <h6 class="card-title">
                    <i class="bi bi-lightbulb text-warning"></i> Conseils
                </h6>
                <ul class="mb-0 small">
                    <li>Seuls les répertoires contenant au moins un fichier YAML valide sont affichés.</li>
                    <li>Seuls les fichiers <strong>.yml</strong> et <strong>.yaml</strong> sont pris en compte.</li>
                    <li>Les fichiers vides ou sans nom sont ignorés automatiquement.</li>
                    <li>Cliquez sur une icône <i class="bi bi-eye"></i> pour afficher le contenu du fichier.</li>
                    <li>Utilisez <i class="bi bi-download"></i> pour télécharger le fichier.</li>
                    <li>
                        Cliquez sur <i class="bi bi-plus-circle text-success"></i> pour
                        <strong>ajouter le fichier à votre espace personnel</strong> dans l’application.
                        Il sera alors accessible dans votre liste privée de fichiers YAML.
                    </li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">📂 Arborescence du dépôt</h5>
            </div>

            <div class="card-body tree-container">
                {% import 'gitlab/macro_arborescence.html.twig' as tree %}
                <ul class="tree-root">
                    {{ tree.render_tree(tree) }}
                </ul>
            </div>
        </div>
    </div>
{% endblock %}

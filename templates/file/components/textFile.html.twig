<form method="post" id="file-form" class="bg-light p-4 rounded shadow-sm">

    {% if show_description %}
        <div class="mb-4">
            <label for="desc" class="form-label fw-semibold">
                📄 Description
            </label>
            <textarea id="desc"
                      name="description"
                      class="form-control"
                      rows="3"
                      placeholder="Description du fichier...">{{ textFile.description }}</textarea>
        </div>
    {% endif %}

    <div class="mb-4">
        <label for="editor" class="form-label fw-semibold">
            📝 Contenu du fichier
            <small class="text-muted">({{ textFile.nameFile }})</small>
        </label>
        <textarea id="editor"
                  name="text_content"
                  data-filename="{{ textFile.nameFile }}"
                  class="form-control"
                  rows="20">{{ textFile.bodyFile }}</textarea>
    </div>

    <input type="hidden" name="_token" value="{{ csrf_token('edit-text') }}">

    <div class="d-flex gap-2 justify-content-center mt-4">
        <button type="submit" class="btn btn-primary btn-lg px-4">
            💾 Enregistrer
        </button>
        <a href="{{ cancel_path }}" class="btn btn-outline-secondary btn-lg px-4">
            ← Annuler
        </a>
    </div>

</form>

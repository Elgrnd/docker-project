<tr class="groupe-row" data-nom="{{ groupe.nom|lower }}">
    <td class="groupe-nom-cell">
        <span class="groupe-nom-text">{{ groupe.nom }}</span>
        {% if isAdmin and groupe.etreChef %}
            <small class="groupe-chef-text">({{ groupe.etreChef.login }})</small>
        {% endif %}
    </td>
    <td class="groupe-actions-cell">
        <div class="groupe-actions">
            {% if canEdit %}
                <a href="{{ path('voir_groupe', {id: groupe.id}) }}" class="btn-action btn-edite">Édité</a>
            {% else %}
                <a href="{{ path('voir_groupe', {id: groupe.id}) }}" class="btn-action btn-membre">Membre</a>
            {% endif %}

            <a href="{{ path('fichiers_groupe', {id: groupe.id}) }}" class="btn-action btn-fichier">Fichier</a>

            {% if canEdit %}
                <form method="post"
                      action="{{ path('supprimer_groupe', {id: groupe.id}) }}"
                      class="delete-groupe-form"
                      data-confirm-message="Supprimer ce groupe ?">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-groupe-' ~ groupe.id) }}">
                    <button type="submit" class="btn-action btn-supprimer">Supprimer</button>
                </form>
            {% endif %}
        </div>
    </td>
</tr>
{% extends 'base.html.twig' %}

{% block title %}<title>Configuration GitLab</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/utilisateur/configuration.css') }}">
{% endblock %}


{% block page_content %}

    <div class="container mt-4">

        <h1 class="mb-4">
            🔧 Configuration de l’URL GitLab
        </h1>

        <div class="card mt-3 border-info mb-4">
            <div class="card-body">
                <h6 class="card-title">
                    <i class="bi bi-lightbulb text-warning"></i> Conseils
                </h6>

                <ul class="mb-0 small">
                    <li>
                        Pour un <strong>dépôt public</strong>, l’URL seule suffit.
                    </li>
                    <li>
                        Pour un <strong>dépôt privé</strong>, vous devez fournir un <strong>token GitLab</strong>
                        (il est stocké <strong>chiffré</strong> dans l’application).
                    </li>
                    <li class="mt-2">
                        <strong>Créer un token (Personal Access Token)</strong> :
                        <ol class="mt-1 mb-0">
                            <li>Allez dans GitLab → <strong>Preferences</strong> → <strong>Access Tokens</strong></li>
                            <li>Créez un token (nom + date d’expiration si besoin)</li>
                            <li>Sélectionnez le role reporter au minimum</li>
                            <li>Dans les scopes, cochez <strong>api</strong> (recommandé pour éviter les soucis d’accès)</li>
                            <li>Copiez le token (il ne sera plus affiché ensuite) et collez-le ici</li>
                        </ol>
                    </li>
                    <li class="mt-2">
                        <strong>Droits minimum sur le projet</strong> :
                        votre compte doit être membre du projet avec le rôle
                        <strong>Developer</strong> (ou plus).
                    </li>
                </ul>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-header">
                <h5 class="mb-0">🌐 Définir l’URL GitLab du projet</h5>
            </div>

            <div class="card-body">

                {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

                <div class="mb-3">
                    {{ form_label(form.gitlabUrl) }}
                    {{ form_widget(form.gitlabUrl) }}
                    {{ form_errors(form.gitlabUrl) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.gitlabToken) }}
                    {{ form_widget(form.gitlabToken) }}
                    {{ form_errors(form.gitlabToken) }}
                    <small class="form-text text-muted">
                        Si le dépôt est privé, indiquez un token (scope <strong>api</strong>). Il est stocké chiffré.
                    </small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        💾 Enregistrer
                    </button>

                    <a href="{{ path('repertoire') }}" class="btn btn-secondary">
                        ↩️ Retour
                    </a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>

{% endblock %}

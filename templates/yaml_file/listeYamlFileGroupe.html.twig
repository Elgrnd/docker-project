{% extends 'base.html.twig' %}

{% block title %}
    <title>Fichiers YAML - {{ groupe.nom }}</title>
{% endblock %}

{% block page_content %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>
    <div id="modalContent" class="modal-yaml">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-yaml"></div>
    </div>

    <div class="file-explorer">
        <h2 class="title">📂 Fichiers YAML du groupe {{ groupe.nom }}</h2>

        <div class="file-list">
            {% if fichiersGroupe|length > 0 %}
                <ul class="list-group">
                    {% for fichier in fichiersGroupe %}
                        <li class="file-item">
                            <div class="file-info">
                                <i class="bi bi-file-earmark-text file-icon"></i>
                                <span class="file-name">{{ fichier.yamlFile.nameFile }}</span>
                            </div>
                            <div class="file-actions">
                                <i class="bi bi-eye view-icon" title="Afficher"
                                   onclick="afficherContenuYamlFile('{{ fichier.yamlFile.bodyFile|escape('js') }}')"></i>

                                {% if is_granted('GROUPE_FILE_EDIT', fichier) %}
                                    <a href="{{ path('modifier_yaml_file_groupe', {'id': groupe.id, 'yamlId': fichier.yamlFile.id}) }}">
                                        <i class="bi bi-pencil edit-icon" title="Modifier"></i>
                                    </a>
                                {% endif %}

                                {% if is_granted('GROUPE_FILE_DELETE', fichier) %}
                                    <form method="post" action="{{ path('supprimer_yaml_groupe', {'id': groupe.id, 'yamlId': fichier.yamlFile.id}) }}" style="display:inline-block;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ fichier.yamlFile.id) }}">
                                        <button type="submit" class="btn btn-link p-0 m-0 supprimerFichier">
                                            <i class="bi bi-trash bin-icon" title="Supprimer"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="empty-msg">Aucun fichier YAML partagé dans ce groupe.</p>
            {% endif %}
        </div>

        <div class="import-section" style="margin-top: 25px;">
            <fieldset style="margin-bottom: 20px;">
                <legend>📥 Importer un nouveau fichier YAML dans le groupe</legend>
                {{ form_start(formImport) }}
                {{ form_row(formImport.yamlFile) }}
                {{ form_row(formImport.droit) }}
                <button type="submit" class="btn btn-primary">Importer</button>
                {{ form_end(formImport) }}
            </fieldset>

            <fieldset>
                <legend>🔁 Ajouter un fichier personnel à ce groupe</legend>

                {{ form_start(formExistant) }}
                {{ form_row(formExistant.yamlId) }}
                {{ form_row(formExistant.droit) }}
                <button type="submit" class="btn btn-secondary">Partager dans le groupe</button>
                {{ form_end(formExistant) }}
            </fieldset>

        </div>

        <div style="margin-top: 20px;">
            <a href="{{ path('mes_groupes') }}" class="btn btn-secondary">← Retour à mes groupes</a>
        </div>

    </div>


    <style>
        .overlay-blur {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 999;
        }
        .modal-yaml { display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%);
            background:white; padding:20px; border-radius:12px; box-shadow:0 4px 20px rgba(0,0,0,0.3);
            max-width:80%; max-height:80%; overflow-y:auto; z-index:1000; }
        .modal-body-yaml { font-family:monospace; white-space:pre-wrap; background:#f5f5f5;
            padding:15px; border-radius:8px; color:#333; }
        .file-explorer { border:1px solid #ccc; border-radius:10px; padding:16px; max-width:700px;
            background:#fafafa; box-shadow:0 2px 6px rgba(0,0,0,0.1); margin:20px auto; }
        .file-item { display:flex; justify-content:space-between; align-items:center; padding:8px 10px;
            margin-bottom:5px; border-radius:8px; background:white; border:1px solid #e0e0e0;
            transition:background-color .2s, transform .1s; }
        .file-item:hover { background:#f2f2f2; transform:scale(1.01); }
        .file-actions i { cursor:pointer; margin-left:10px; color:#666; transition:color .2s; }
        .file-actions i:hover { color:#007bff; }
    </style>
{% endblock %}

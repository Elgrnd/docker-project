{% extends 'base.html.twig' %}

{% import 'repertoire/components/arborescence.html.twig' as arbre %}
{% import 'repertoire/components/arborescenceGitlab.html.twig' as git %}

{% block title %}<title>Mes Répertoires</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/repertoire/repertoirePerso.css') }}">
{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
    <script defer type="text/javascript" src="{{ asset('js/gestionRepertoire.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-file">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-file"></div>
    </div>


    <div class="container mt-4">
        <h1>Répertoire</h1>

        {# Card Arborescence #}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📂 Arborescence</h5>
                {# Menu déroulant GitLab #}
                {% if app.user.gitlabUrl %}
                    <div class="gitlab-dropdown-container">
                        <button class="btn btn-gitlab-menu" type="button" id="gitlabDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            ⚙️ Options GitLab
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="gitlabDropdown">
                            <li>
                                <a class="dropdown-item" href="{{ path('gitlab_url') }}">
                                    ✏️ Modifier URL GitLab
                                </a>
                            </li>
                            <li>
                                <form method="post" action="{{ path('actualiserGitlab') }}" class="dropdown-item-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('actualiserGitlab') }}">
                                    <button type="submit" class="dropdown-item">
                                        🔄 Actualiser GitLab
                                    </button>
                                </form>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('gitlab_supprimer_url') }}"
                                   onclick="return confirm('Voulez-vous vraiment supprimer votre URL GitLab ?')">
                                    🗑️ Supprimer URL GitLab
                                </a>
                            </li>
                        </ul>
                    </div>
                {% else %}
                    <div class="gitlab-dropdown-container">
                        <a href="{{ path('gitlab_url') }}" class="btn btn-gitlab-menu">
                            ➕ Configurer GitLab
                        </a>
                    </div>
                {% endif %}
            </div>

            <div class="card-body tree-container">
                {% if repertoireRacine %}
                    {{ arbre.render_tree(repertoireRacine, listUyr, 'perso') }}
                {% else %}
                    <p class="text-muted">Aucun répertoire trouvé.</p>
                {% endif %}

                <hr class="my-4">

                {% if gitlabTree %}
                    {{ git.render_tree(gitlabTree) }}
                {% else %}
                    <p class="text-muted">Aucun dépôt GitLab configuré.</p>
                {% endif %}
            </div>

            {# Boutons d'action #}
            <div class="btn-actions-group">
                <a href="{{ path('repertoire_telecharger_zip', {id: repertoireRacine.id}) }}"
                   class="btn btn-primary">
                    Télécharger En ZIP
                </a>

                {% if app.user and app.user.vmStatus == 'ready' %}
                    <a href="{{ path('repertoire_copier_vm', {'id': repertoireRacine.id}) }}"
                       class="btn btn-primary">
                        ⬆️ Copier dans la VM
                    </a>
                {% endif %}

                <a href="{{ path('repertoire_corbeille') }}" class="btn btn-outline-danger">
                    Voir La Corbeille
                </a>
            </div>
        </div>



        {# Section création nouveau répertoire #}
        <div id="formContainer">
            <div class="card-header">
                <h5 class="mb-0">Créer Un Nouveau Repertoire</h5>
            </div>
            <div class="card-body">
                {{ form_start(formRepertoire, {'attr': {'class': 'needs-validation'}}) }}

                <div class="mb-3">
                    {{ form_label(formRepertoire.name, 'Nom Repertoire') }}
                    {{ form_widget(formRepertoire.name, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(formRepertoire.name) }}
                </div>

                <div class="mb-3">
                    {{ form_label(formRepertoire.parent, 'Repertoire Parent') }}
                    {{ form_widget(formRepertoire.parent, {'attr': {'class': 'form-select'}}) }}
                    <small class="form-text">
                        Le Répertoire Personnel Est Sélectionné Par Défaut
                    </small>
                    {{ form_errors(formRepertoire.parent) }}
                </div>

                <button type="submit" class="btn btn-primary">Créer</button>

                {{ form_end(formRepertoire) }}
            </div>
        </div>

    </div>

{% endblock %}
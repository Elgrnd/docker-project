{% extends 'base.html.twig' %}

{% block title %}
    <title>Versions de {{ textFile.nameFile }}</title>
{% endblock %}

{% block page_content %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Historique des versions - {{ textFile.nameFile }}</h1>
            <a href="{{ path('repertoire') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste des fichiers
            </a>
        </div>

        {% if versions is empty %}
            <div class="alert alert-info">
                Aucune version n'a été trouvée pour ce fichier.
            </div>
        {% else %}
            <div class="card">
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                        <tr>
                            <th>Date d'édition</th>
                            <th>Modifié par</th>
                            <th>Commentaire</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for version in versions %}
                            <tr>
                                <td>{{ version.dateEdition|date('d/m/Y H:i:s') }}</td>
                                <td>
                                    {{ version.utilisateur ? version.utilisateur.login : 'Inconnu' }}
                                </td>
                                <td>{{ version.commentaire ?? 'Aucun commentaire' }}</td>
                                <td>
                                    <a href="{% if isGroupe %}
                                                {{ path('version_detail_groupe', {'groupeId': groupe.id, 'versionId': version.id}) }}
                                            {% else %}
                                                {{ path('version_detail', {'id': version.id}) }}
                                            {% endif %}"
                                       class="btn btn-sm btn-primary"
                                       title="Voir les détails">
                                        <i class="fas fa-eye"></i> Voir
                                    </a>
                                    <a href="{% if isGroupe %}
                                                {{ path('version_restore_groupe', {'groupeId': groupe.id, 'versionId': version.id}) }}
                                            {% else %}
                                                {{ path('version_restore', {'id': version.id}) }}
                                            {% endif %}"
                                       class="btn btn-sm btn-warning"
                                       onclick="return confirm('Êtes-vous sûr de vouloir restaurer cette version ?')"
                                       title="Restaurer cette version">
                                        <i class="fas fa-undo"></i> Restaurer
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
{% extends 'base.html.twig' %}

{% import 'repertoire/components/arborescence.html.twig' as arbre %}

{% block title %}<title>Mes Répertoires</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/repertoire/repertoirePerso.css') }}">
{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
    <script defer type="text/javascript" src="{{ asset('js/gestionRepertoire.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-file">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-file"></div>
    </div>


    <div class="container mt-4">
        <h1>Répertoire</h1>

        {# Card Arborescence avec bouton GitLab #}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">📂 Arborescence</h5>
                <a href="{{ path('gitlab_fichiers') }}" class="btn-gitlab">GitLab</a>
            </div>
            <div class="card-body tree-container">
                {% if repertoireRacine %}
                    {{ arbre.render_tree(repertoireRacine, listUyr, 'perso') }}
                {% else %}
                    <p class="text-muted">Aucun répertoire trouvé.</p>
                {% endif %}
            </div>

            {# Boutons d'action #}
            <div class="btn-actions-container">
                <a href="{{ path('repertoire_telecharger_zip', {id: repertoireRacine.id}) }}"
                   class="btn btn-primary mt-3">
                    Télécharger En ZIP
                </a>

                <a href="{{ path('repertoire_corbeille') }}" class="btn btn-outline-danger">
                    Voir La Corbeille
                </a>
            </div>
        </div>

        {# Section création nouveau répertoire #}
        <div class="create-section">
            <h3>Créer Un Nouveau Repertoire</h3>

            {{ form_start(formRepertoire, {'attr': {'class': 'needs-validation'}}) }}

            <div class="mb-3">
                {{ form_label(formRepertoire.name, 'Nom Repertoire') }}
                {{ form_widget(formRepertoire.name, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(formRepertoire.name) }}
            </div>

            <div class="mb-3">
                {{ form_label(formRepertoire.parent, 'Repertoire Parent') }}
                {{ form_widget(formRepertoire.parent, {'attr': {'class': 'form-select'}}) }}
                <small class="form-text">
                    Le Répertoire Personnel Est Sélectionné Par Défaut
                </small>
                {{ form_errors(formRepertoire.parent) }}
            </div>

            <button type="submit" class="btn btn-primary">Créer</button>

            {{ form_end(formRepertoire) }}
        </div>

        {% if app.user and app.user.vmStatus == 'ready' %}
            <a href="{{ path('repertoire_copier_vm', {'id': repertoireRacine.id}) }}"
               class="btn btn-primary mt-3">
                ⬆️ Copier mon répertoire dans la VM
            </a>
        {% endif %}

    </div>

{% endblock %}
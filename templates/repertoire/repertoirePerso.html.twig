{% extends 'base.html.twig' %}

{% import 'repertoire/components/arborescence.html.twig' as arbre %}
{% import 'repertoire/components/arborescenceGitlab.html.twig' as git %}

{% block title %}<title>Mes Répertoires</title>{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/repertoire/repertoirePerso.css') }}">
{% endblock %}

{% block scriptJs %}
    <script defer type="text/javascript" src="{{ asset('js/gestionEvent.js') }}"></script>
    <script defer type="text/javascript" src="{{ asset('js/gestionRepertoire.js') }}"></script>
{% endblock %}

{% block page_content %}

    <div id="overlayBlur" class="overlay-blur" onclick="cacherBlur()"></div>

    <div id="modalContent" class="modal-file">
        <div class="modal-header">
            <span class="close-modal" onclick="cacherBlur()">&times;</span>
        </div>
        <div id="contentDisplay" class="modal-body-file"></div>
    </div>


    <div class="container mt-4">
        <h1>Gestion des répertoires</h1>


        {# Bouton pour afficher le formulaire #}
        <div class="mb-4">
            <a href="#" id="toggleFormBtn" class="btn btn-success">
                ➕ Créer un nouveau répertoire
            </a>
        </div>

        {# Formulaire de création (masqué par défaut) #}
        {{ include('repertoire/components/formulaireCreation.html.twig', {'form': formRepertoire}) }}

    <div class="d-flex flex-wrap gap-2 mt-3 align-items-center">
        <a href="{{ path('repertoire_telecharger_zip', {id: repertoireRacine.id}) }}"
           class="btn btn-primary">
            📦 Télécharger en ZIP (répertoire personnel)
        </a>

        {% if app.user and app.user.vmStatus == 'ready' %}
            <a href="{{ path('repertoire_copier_vm', {'id': repertoireRacine.id}) }}"
               class="btn btn-primary">
                ⬆️ Copier mon répertoire dans la VM
            </a>
        {% endif %}

        <a href="{{ path('gitlab_url') }}" class="btn btn-outline-primary">
            ✏️ Modifier URL GitLab
        </a>

        {% if app.user.gitlabUrl %}
            <form method="post" action="{{ path('actualiserGitlab') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('actualiserGitlab') }}">
                <button type="submit" class="btn btn-outline-warning">
                    🔄 Actualiser GitLab
                </button>
            </form>

            <a href="{{ path('gitlab_supprimer_url') }}"
               class="btn btn-outline-danger"
               onclick="return confirm('Voulez-vous vraiment supprimer votre URL GitLab ?')">
                🗑️ Supprimer URL GitLab
            </a>
        {% endif %}
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h5 class="mb-0">📂 Arborescences</h5>
        </div>

        <div class="card-body tree-container">

            {% if repertoireRacine %}
                {{ arbre.render_tree(repertoireRacine, listUyr, 'perso') }}
            {% else %}
                <p class="text-muted">Aucun répertoire trouvé.</p>
            {% endif %}

            <hr class="my-4">

            {% if gitlabTree %}
                {{ git.render_tree(gitlabTree) }}
            {% else %}
                <p class="text-muted">Aucun dépôt GitLab configuré.</p>
            {% endif %}
        </div>
    </div>



    <div class="card mt-4">
        <div class="card-header">
            <h5 class="mb-0">🗑️ Corbeille</h5>
        </div>
        <div class="card-body">
            <a href="{{ path('repertoire_corbeille') }}" class="btn btn-outline-danger">
                Voir les éléments supprimés
            </a>
        </div>
    </div>

{% endblock %}
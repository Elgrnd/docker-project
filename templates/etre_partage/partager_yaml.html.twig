{% extends "base.html.twig" %}

{% block title %}
    <title>Partager un fichier YAML</title>
{% endblock %}

{% block page_content %}
    <main class="share-container">
        <div class="card-share">
            <h2 class="title text-center mb-3">📤 Partager un fichier YAML</h2>
            <p class="subtitle text-muted mb-4 text-center">
                {% if is_granted('ROLE_ADMIN') %}
                    Vous êtes en mode administrateur — vous pouvez partager n’importe quel fichier.
                {% else %}
                    Vous pouvez partager vos fichiers YAML avec d’autres utilisateurs.
                {% endif %}
            </p>

            {{ form_start(formulairePartage) }}
            <div class="mb-3">
                {{ form_label(formulairePartage.yamlFile, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                {{ form_widget(formulairePartage.yamlFile, {'attr': {'class': 'form-select'}}) }}
            </div>

            <div class="mb-3">
                {{ form_label(formulairePartage.utilisateur, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                {{ form_widget(formulairePartage.utilisateur, {'attr': {'class': 'form-select'}}) }}
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-share"></i> Partager
                </button>
            </div>
            {{ form_end(formulairePartage) }}
        </div>
    </main>

    <style>
        .share-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 80vh;
            background: #f8f9fa;
        }

        .card-share {
            background: #fff;
            padding: 30px 40px;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
            font-family: system-ui, sans-serif;
        }

        .card-share .title {
            font-size: 1.8rem;
            font-weight: 600;
            color: #333;
        }

        .subtitle {
            font-size: 0.95rem;
        }

        .form-select {
            border-radius: 8px;
            border: 1px solid #ccc;
            padding: 8px 10px;
        }

        .btn-primary {
            background-color: #007bff;
            border: none;
            border-radius: 8px;
            transition: background-color 0.2s ease;
        }

        .btn-primary:hover {
            background-color: #0069d9;
        }
    </style>
{% endblock %}
